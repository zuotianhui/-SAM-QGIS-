<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>SamSegmentationDialogBase</class>
 <widget class="QDialog" name="SamSegmentationDialogBase">
  <property name="geometry">
   <rect>
    <x>100</x>
    <y>100</y>
    <width>600</width>
    <height>500</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>SAM2影像自动分割标注工具</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <!-- 顶部按钮栏 -->
   <widget class="QWidget" name="topButtonWidget" native="true">
    <layout class="QHBoxLayout" name="horizontalLayout">
     <widget class="QPushButton" name="btn_switch_to_function">
      <property name="text">
       <string>功能面板</string>
      </property>
     </widget>
     <widget class="QPushButton" name="btn_switch_to_params">
      <property name="text">
       <string>参数设置</string>
      </property>
     </widget>
     <spacer name="horizontalSpacer">
      <property name="orientation">
       <enum>Qt::Horizontal</enum>
      </property>
      <property name="sizeHint" stdset="0">
       <size>
        <width>40</width>
        <height>20</height>
       </size>
      </property>
     </spacer>
    </layout>
   </widget>
   
   <!-- 堆叠窗口 -->
   <widget class="QStackedWidget" name="stacked_widget">
    <!-- 功能面板 -->
    <widget class="QWidget" name="page_function">
     <layout class="QVBoxLayout" name="verticalLayout_2">
      <!-- 图层选择 -->
      <widget class="QGroupBox" name="groupBox">
       <property name="title">
        <string>图层设置</string>
       </property>
       <layout class="QVBoxLayout" name="verticalLayout_3">
        <layout class="QHBoxLayout" name="horizontalLayout_2">
         <widget class="QLabel" name="label">
          <property name="text">
           <string>选择栅格图层:</string>
          </property>
         </widget>
         <widget class="QComboBox" name="layerCombo"/>
        </layout>
        <layout class="QHBoxLayout" name="horizontalLayout_3">
         <widget class="QLabel" name="sampleSizeLabel">
          <property name="text">
           <string>最大处理尺寸：2000px</string>
          </property>
         </widget>
         <widget class="QSlider" name="sampleSizeSlider">
          <property name="minimum">
           <number>500</number>
          </property>
          <property name="maximum">
           <number>4000</number>
          </property>
          <property name="value">
           <number>2000</number>
          </property>
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
         </widget>
        </layout>
       </layout>
      </widget>
      
      <!-- 模型设置 -->
      <widget class="QGroupBox" name="groupBox_2">
       <property name="title">
        <string>模型设置</string>
       </property>
       <layout class="QVBoxLayout" name="verticalLayout_4">
        <layout class="QHBoxLayout" name="horizontalLayout_4">
         <widget class="QLabel" name="label_2">
          <property name="text">
           <string>模型类型:</string>
          </property>
         </widget>
         <widget class="QComboBox" name="modelTypeCombo">
          <item>
           <property name="text">
            <string>vit_l</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>vit_b</string>
           </property>
          </item>
          <item>
           <property name="text">
            <string>vit_h</string>
           </property>
          </item>
         </widget>
        </layout>
        <layout class="QHBoxLayout" name="horizontalLayout_5">
         <widget class="QLabel" name="label_3">
          <property name="text">
           <string>模型文件:</string>
          </property>
         </widget>
         <widget class="QLineEdit" name="modelPathValue"/>
         <widget class="QPushButton" name="browseModelBtn">
          <property name="text">
           <string>浏览</string>
          </property>
         </widget>
        </layout>
        <layout class="QHBoxLayout" name="horizontalLayout_6">
         <widget class="QLabel" name="label_4">
          <property name="text">
           <string>配置文件:</string>
          </property>
         </widget>
         <widget class="QLineEdit" name="configPathValue"/>
         <widget class="QPushButton" name="browseConfigBtn">
          <property name="text">
           <string>浏览</string>
          </property>
         </widget>
        </layout>
        <widget class="QPushButton" name="loadModelBtn">
         <property name="text">
          <string>加载模型</string>
         </property>
        </widget>
       </layout>
      </widget>
      
      <!-- 标注操作 -->
      <widget class="QGroupBox" name="groupBox_3">
       <property name="title">
        <string>标注操作</string>
       </property>
       <layout class="QHBoxLayout" name="horizontalLayout_7">
        <widget class="QPushButton" name="foregroundBtn">
         <property name="text">
          <string>前景点</string>
         </property>
        </widget>
        <widget class="QPushButton" name="backgroundBtn">
         <property name="text">
          <string>背景点</string>
         </property>
        </widget>
        <widget class="QPushButton" name="undoBtn">
         <property name="text">
          <string>撤销</string>
         </property>
        </widget>
        <widget class="QPushButton" name="clearBtn">
         <property name="text">
          <string>清除</string>
         </property>
        </widget>
        <widget class="QPushButton" name="saveShpBtn">
         <property name="text">
          <string>保存为Shapefile</string>
         </property>
        </widget>
       </layout>
      </widget>
      
      <!-- 日志区域 -->
      <widget class="QGroupBox" name="groupBox_4">
       <property name="title">
        <string>操作日志</string>
       </property>
       <layout class="QVBoxLayout" name="verticalLayout_5">
        <widget class="QTextEdit" name="logText">
         <property name="readOnly">
          <bool>true</bool>
         </property>
        </widget>
       </layout>
      </widget>
     </layout>
    </widget>
    
    <!-- 参数设置面板 -->
    <widget class="QWidget" name="page_params">
     <layout class="QVBoxLayout" name="verticalLayout_6">
      <widget class="QTabWidget" name="tabWidget">
       <!-- 分割参数 -->
       <widget class="QWidget" name="tab_segment">
        <attribute name="title">
         <string>分割参数</string>
        </attribute>
        <layout class="QVBoxLayout" name="segment_layout"/>
       </widget>
       
       <!-- 掩码处理参数 -->
       <widget class="QWidget" name="tab_mask">
        <attribute name="title">
         <string>掩码处理</string>
        </attribute>
        <layout class="QVBoxLayout" name="mask_layout"/>
       </widget>
       
       <!-- 矢量转换参数 -->
       <widget class="QWidget" name="tab_vector">
        <attribute name="title">
         <string>矢量转换</string>
        </attribute>
        <layout class="QVBoxLayout" name="vector_layout"/>
       </widget>
      </widget>
     </layout>
    </widget>
   </widget>
   
   <!-- 底部按钮 -->
   <widget class="QDialogButtonBox" name="buttonBox">
    <property name="standardButtons">
     <set>QDialogButtonBox::Close</set>
    </property>
   </widget>
  </layout>
 </widget>
 <layoutdefault spacing="6" margin="11"/>
 <customwidgets>
  <customwidget>
   <class>QgsMapTool</class>
   <extends>QObject</extends>
   <header>qgis.gui</header>
  </customwidget>
 </customwidgets>
 <resources/>
 <connections>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>SamSegmentationDialogBase</receiver>
   <slot>reject()</slot>
   <hints>
    <hint type="sourcelabel">
     <x>528</x>
     <y>476</y>
    </hint>
    <hint type="destinationlabel">
     <x>528</x>
     <y>250</y>
    </hint>
   </hints>
  </connection>
 </connections>
</ui>